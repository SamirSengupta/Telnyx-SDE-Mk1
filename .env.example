# Quinn local configuration — copy to `.env` and fill in what you have.
# Every integration is OPTIONAL: without a value, that channel automatically
# falls back to a safe offline logger (nothing external is ever contacted).

# --- LLM proxy (required for live runs; tests never need it) ---------------
# Any OpenAI-compatible /v1/chat/completions endpoint works.
# Default: a local CLIProxyAPI instance.
QUINN_PROXY_URL=http://localhost:8317/v1
QUINN_PROXY_KEY=dummy

# Optional per-task model overrides (also settable live in the dashboard's
# "Configure Agent" tab):
# QUINN_MODEL_QUALIFY=claude-sonnet-4-6
# QUINN_MODEL_JUDGE=claude-opus-4-6-thinking
# QUINN_MODEL_COMPOSE=gemini-3.1-pro-low
# QUINN_MODEL_APPROVE=claude-sonnet-4-6

# --- Slack (optional) -------------------------------------------------------
# Incoming Webhook URL; review cards + run summaries are posted here.
# QUINN_SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Gmail (optional) -------------------------------------------------------
# Path to a Google OAuth "Desktop app" client JSON. Scope used is
# gmail.compose (drafts + send only — no mailbox read).
# One-time consent: py -m quinn.gmail
# QUINN_GMAIL_CREDS=gmail_creds.json
# QUINN_GMAIL_TOKEN=gmail_token.json
